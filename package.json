{
  "name": "market-brain",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Christian Yoon",
  "repository": {
    "type": "git",
    "url": "https://github.com/sha-sta/market-brain.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "e2e": "playwright test",
    "db:start": "set -a; . ./.env.local 2>/dev/null || true; set +a; supabase start",
    "db:stop": "supabase stop",
    "db:reset": "set -a; . ./.env.local 2>/dev/null || true; set +a; supabase db reset",
    "db:types": "tmp=$(mktemp); (cd /tmp && SUPABASE_ACCESS_TOKEN=local \"$INIT_CWD/node_modules/.bin/supabase\" gen types typescript --db-url postgresql://postgres:postgres@127.0.0.1:55322/postgres) > \"$tmp\" && mv \"$tmp\" src/lib/database.types.ts",
    "db:test:start": "supabase start --workdir supabase-test",
    "db:test:stop": "supabase stop --workdir supabase-test",
    "db:test:reset": "supabase db reset --workdir supabase-test",
    "seed": "tsx scripts/seed.ts",
    "eval:fetch-corpus": "tsx scripts/eval/fetch-corpus.ts",
    "eval:grounding": "vitest run --config vitest.eval.config.ts scripts/eval/grounding.eval.ts",
    "eval:precision": "vitest run --config vitest.eval.config.ts scripts/eval/precision.eval.ts",
    "eval:score": "tsx scripts/eval/score.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "ai": "^6.0.204",
    "fuzzball": "^2.2.6",
    "next": "16.2.9",
    "nodemailer": "^6.9.16",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "supabase": "^2.106.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
