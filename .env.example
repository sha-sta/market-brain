# MarketBrain — environment template. Copy to .env.local (dev) / set in Vercel (prod).
# Never commit real values. Missing optional keys = that feature lies dormant (never crashes boot).

# --- Supabase (client-safe: shipped to the browser) ---
# Local dev values come from `supabase start` output; prod from the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only: NEVER expose to the client) ---
# Used by src/lib/supabase/admin.ts (the normalize worker + daily cron upsert with this).
SUPABASE_SERVICE_ROLE_KEY=

# --- Vercel AI Gateway (one key for Claude generation + OpenAI embeddings) ---
# Models referenced as "anthropic/claude-sonnet-4.6" / "openai/text-embedding-3-small".
# REQUIRED for extraction, the brief, and Ask. Paid credits.
AI_GATEWAY_API_KEY=

# --- Email: morning brief ---
# PREFERRED (no domain needed, reaches any inbox like dad's Gmail): send from a Gmail account via an
# App Password. Enable 2-Step Verification on the account, then Google Account > Security > App
# passwords to generate the 16-char password (NOT the normal password).
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Recipient of the brief (dad's email). If unset, the brief is sent to GMAIL_USER.
DIGEST_TO=
# IANA timezone; the brief is gated to one send per ET date by default.
DIGEST_TZ=America/New_York
#
# ALTERNATIVE sender (only used when GMAIL_APP_PASSWORD is unset): Resend. Its free tier only delivers
# to your own account email until you verify a sending DOMAIN, so it needs RESEND_FROM on that domain.
RESEND_API_KEY=
RESEND_FROM=

# --- Market data adapters (all OPTIONAL; missing key = that source is skipped, run degrades) ---
# Finnhub — primary quotes + company news. Free tier 60 req/min. https://finnhub.io
FINNHUB_API_KEY=
# Financial Modeling Prep — profiles, earnings calendar, ratings/price-target deltas. Free 250/day. https://financialmodelingprep.com
FMP_API_KEY=
# Alpha Vantage — news sentiment. Free 25/day (severe); theme-level only / fallback. https://www.alphavantage.co
ALPHAVANTAGE_API_KEY=
# SEC EDGAR is keyless but REQUIRES a User-Agent string of the form "Name email@example.com".
# SEC rejects requests without it. https://www.sec.gov/os/accessing-edgar-data
SEC_EDGAR_UA=

# Exa — open-web search + content extraction for gated research requests. Dormant when unset (research
# then re-reads the current graph only). https://exa.ai
EXA_API_KEY=
# Max interactive research jobs per user per rolling 24h (the cost quota). Default 5.
RESEARCH_DAILY_QUOTA=

# --- Auth (Supabase Auth Google provider) ---
# Access is gated by an approved-users allowlist (profiles.active); bootstrap admin seeded below.
# LOCAL DEV: supabase/config.toml reads these to enable Google sign-in against the local stack.
# PROD: configure Google in the Supabase dashboard (Auth > Providers) + add redirect URIs in the
# Google Cloud console; these two vars are then unused in prod.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Bootstrap ---
# Email promoted to the first active admin (matches a profiles row via the auth trigger).
BOOTSTRAP_ADMIN_EMAIL=

# --- Cron ---
# Shared secret the daily cron requires as a Bearer token. Endpoints FAIL CLOSED: if unset they
# return 401 (never open to the internet). Set the same value on the Vercel cron.
CRON_SECRET=

# --- E2e (optional) ---
# E2E_BASE_URL=http://localhost:3000
